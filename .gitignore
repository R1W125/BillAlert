# ============================================================
# BillAlert — .gitignore
# Place ALL secrets and API keys in backend/.env (never commit it)
# ============================================================

# ----- Environment / Secrets --------------------------------
# This is where your API keys live — NEVER commit these files
.env
.env.local
.env.development
.env.production
.env.test
backend/.env
backend/.env.*

# ----- Node.js ----------------------------------------------
node_modules/
backend/node_modules/
extension/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ----- SQLite Database (contains user data) -----------------
backend/db/data/
backend/data/
*.db
*.sqlite
*.sqlite3

# ----- macOS ------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ----- Editor / IDE -----------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Build / Dist -----------------------------------------
dist/
build/
*.zip

# ----- Logs -------------------------------------------------
*.log
logs/
.Rhistory
