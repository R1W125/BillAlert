{
  "name": "bilalert-backend",
  "version": "1.0.0",
  "description": "BillAlert backend API — scans Gmail emails via Gemini and tracks monthly usage",
  "main": "server.js",
  "scripts": {
    "start": "node --no-experimental-warnings server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "MIT"
}
